<Window x:Class="SpoutDirectSaver.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        mc:Ignorable="d"
        Title="Spout Direct Saver"
        Width="1360"
        Height="900"
        MinWidth="1120"
        MinHeight="760"
        Background="#10151C">
    <Window.Resources>
        <DrawingBrush x:Key="CheckerBrush"
                      TileMode="Tile"
                      Stretch="None"
                      Viewport="0,0,24,24"
                      ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#1B2530" Geometry="M0,0 H24 V24 H0 Z" />
                    <GeometryDrawing Brush="#243140" Geometry="M0,0 H12 V12 H0 Z" />
                    <GeometryDrawing Brush="#243140" Geometry="M12,12 H24 V24 H12 Z" />
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F2F6FB" />
            <Setter Property="Background" Value="#1D5C58" />
            <Setter Property="BorderBrush" Value="#2C7B76" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E9F0F7" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1.05*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.1*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="#18212B"
                BorderBrush="#263445"
                BorderThickness="1"
                CornerRadius="14"
                Padding="18"
                Margin="0,0,0,16">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Vertical" DockPanel.Dock="Left">
                    <TextBlock FontSize="26" FontWeight="SemiBold" Text="Spout Direct Saver" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#9DB1C6"
                               Text="Spout2 のフレームを受信し、変化フレームのみを可変fpsで動画化します。" />
                </StackPanel>
                <Border DockPanel.Dock="Right"
                        Background="#121820"
                        BorderBrush="#324558"
                        BorderThickness="1"
                        CornerRadius="999"
                        Padding="14,8">
                    <TextBlock x:Name="HeaderStatusTextBlock"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Text="初期化中..." />
                </Border>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="0"
                Background="#18212B"
                BorderBrush="#263445"
                BorderThickness="1"
                CornerRadius="18"
                Padding="16"
                Margin="0,0,16,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,12">
                    <StackPanel Orientation="Vertical" DockPanel.Dock="Left">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="ライブ入力" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="#8FA4B9"
                                   Text="RGBA 8bit で受信し、ここではチェック柄の上にプレビュー表示します。" />
                    </StackPanel>
                    <Border DockPanel.Dock="Right"
                            Background="#121820"
                            BorderBrush="#324558"
                            BorderThickness="1"
                            CornerRadius="999"
                            Padding="12,6">
                        <TextBlock x:Name="LivePreviewBadgeTextBlock"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Text="入力待ち" />
                    </Border>
                </DockPanel>

                <Border Grid.Row="1"
                        Background="{StaticResource CheckerBrush}"
                        BorderBrush="#33475C"
                        BorderThickness="1"
                        CornerRadius="14"
                        ClipToBounds="True">
                    <Grid>
                        <Image x:Name="LivePreviewImage" Stretch="Uniform" />
                        <Border x:Name="LivePreviewPlaceholderBorder"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Background="#A010151C"
                                CornerRadius="12"
                                Padding="18,14">
                            <TextBlock x:Name="LivePreviewPlaceholderTextBlock"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="Spout sender を待っています" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="1"
                Background="#18212B"
                BorderBrush="#263445"
                BorderThickness="1"
                CornerRadius="18"
                Padding="16"
                Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="18" FontWeight="SemiBold" Text="受信状況" />

                <TextBlock Grid.Row="1" Margin="0,18,0,4" Foreground="#8FA4B9" Text="Sender" />
                <TextBlock Grid.Row="2" x:Name="SenderNameTextBlock" FontSize="16" FontWeight="SemiBold" Text="-" />

                <TextBlock Grid.Row="3" Margin="0,16,0,4" Foreground="#8FA4B9" Text="解像度 / sender fps" />
                <TextBlock Grid.Row="4" x:Name="SenderMetricsTextBlock" FontSize="16" FontWeight="SemiBold" Text="- / -" />

                <TextBlock Grid.Row="5" Margin="0,16,0,4" Foreground="#8FA4B9" Text="録画経過" />
                <TextBlock Grid.Row="6" x:Name="RecordingElapsedTextBlock" FontSize="16" FontWeight="SemiBold" Text="00:00:00.000" />

                <TextBlock Grid.Row="7" Margin="0,16,0,4" Foreground="#8FA4B9" Text="状態" />
                <Border Grid.Row="8"
                        Background="#121820"
                        BorderBrush="#324558"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="12">
                    <TextBlock x:Name="RecorderStatusTextBlock"
                               TextWrapping="Wrap"
                               Foreground="#DCE8F5"
                               Text="録画前です。" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Grid.ColumnSpan="2"
                Background="#18212B"
                BorderBrush="#263445"
                BorderThickness="1"
                CornerRadius="18"
                Padding="16"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           FontWeight="SemiBold"
                           Text="保存形式" />
                <ComboBox Grid.Row="0"
                          Grid.Column="1"
                          x:Name="FormatComboBox"
                          Height="34"
                          VerticalContentAlignment="Center"
                          SelectionChanged="FormatComboBox_OnSelectionChanged" />

                <TextBlock Grid.Row="0"
                           Grid.Column="3"
                           x:Name="FormatDescriptionTextBlock"
                           VerticalAlignment="Center"
                           Foreground="#96AABD"
                           TextWrapping="Wrap"
                           Text="RGBA をそのまま保存できる形式を選びます。" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,16,10,0"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Text="保存先" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Grid.ColumnSpan="3"
                         x:Name="OutputPathTextBox"
                         Margin="0,16,10,0"
                         Height="34"
                         IsReadOnly="True"
                         VerticalContentAlignment="Center" />
                <Button Grid.Row="1"
                        Grid.Column="4"
                        x:Name="BrowseOutputButton"
                        Margin="0,16,0,0"
                        Click="BrowseOutputButton_OnClick"
                        Content="保存先を選択" />
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Grid.ColumnSpan="2"
                Background="#18212B"
                BorderBrush="#263445"
                BorderThickness="1"
                CornerRadius="18"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,12">
                    <StackPanel Orientation="Vertical" DockPanel.Dock="Left">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="録画プレビュー" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="#8FA4B9"
                                   Text="停止後に保存した動画をそのまま再生します。" />
                    </StackPanel>
                    <TextBlock x:Name="PreviewFileTextBlock"
                               DockPanel.Dock="Right"
                               VerticalAlignment="Center"
                               Foreground="#96AABD"
                               Text="まだ録画されていません" />
                </DockPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <Button x:Name="StartRecordingButton" Click="StartRecordingButton_OnClick" Content="録画開始" />
                    <Button x:Name="StopRecordingButton"
                            Background="#7A2F36"
                            BorderBrush="#A84A53"
                            Click="StopRecordingButton_OnClick"
                            Content="録画停止" />
                    <Button x:Name="RerecordButton"
                            Background="#344756"
                            BorderBrush="#476175"
                            Click="RerecordButton_OnClick"
                            Content="再録画" />
                    <Button x:Name="PlayPreviewButton"
                            Background="#395C41"
                            BorderBrush="#4B7C56"
                            Click="PlayPreviewButton_OnClick"
                            Content="再生" />
                    <Button x:Name="PausePreviewButton"
                            Background="#344756"
                            BorderBrush="#476175"
                            Click="PausePreviewButton_OnClick"
                            Content="一時停止" />
                </StackPanel>

                <Border Grid.Row="2"
                        Margin="0,14,0,0"
                        Background="#121820"
                        BorderBrush="#33475C"
                        BorderThickness="1"
                        CornerRadius="14"
                        ClipToBounds="True">
                    <Grid>
                        <vlc:VideoView x:Name="PreviewVideoView" />
                        <Border x:Name="PreviewPlaceholderBorder"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Background="#A010151C"
                                CornerRadius="12"
                                Padding="18,14">
                            <TextBlock x:Name="PreviewPlaceholderTextBlock"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="録画停止後にここでプレビュー再生できます" />
                        </Border>
                    </Grid>
                </Border>

                <Slider Grid.Row="3"
                        x:Name="SeekSlider"
                        Margin="0,14,0,0"
                        Height="28"
                        Minimum="0"
                        Maximum="1"
                        IsSnapToTickEnabled="False"
                        PreviewMouseLeftButtonDown="SeekSlider_OnPreviewMouseLeftButtonDown"
                        PreviewMouseLeftButtonUp="SeekSlider_OnPreviewMouseLeftButtonUp" />

                <DockPanel Grid.Row="4" Margin="0,10,0,0">
                    <TextBlock x:Name="PreviewStatusTextBlock"
                               DockPanel.Dock="Left"
                               Foreground="#DCE8F5"
                               Text="プレビュー待機中です。" />
                    <TextBlock x:Name="PreviewTimeTextBlock"
                               DockPanel.Dock="Right"
                               Foreground="#9DB1C6"
                               Text="00:00:00.000 / 00:00:00.000" />
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
