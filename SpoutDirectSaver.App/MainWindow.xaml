<Window x:Class="SpoutDirectSaver.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Spout Direct Saver"
        Width="1024"
        Height="768"
        MinWidth="1024"
        MinHeight="768"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#434343"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="112" />
            <Setter Property="Height" Value="112" />
            <Setter Property="Margin" Value="0,0,14,0" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Foreground" Value="#F4F4F4" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#5D5D5D" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#7A7A7A" />
                                <Setter Property="Foreground" Value="#B8B8B8" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.96" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="RenderTransformOrigin" Value="0.5,0.5" />
                                <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D0D0D0" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F4F4F4" />
            <Setter Property="FontSize" Value="38" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="MetricSeparatorStyle" TargetType="Border">
            <Setter Property="Background" Value="#8F8F8F" />
            <Setter Property="Width" Value="4" />
            <Setter Property="Height" Value="58" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="Opacity" Value="0.95" />
        </Style>
    </Window.Resources>

    <Grid Background="#434343">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="InitialMetricsPanel"
              Margin="92,42,92,0"
              HorizontalAlignment="Left"
              VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="34" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="34" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel MinWidth="160">
                <TextBlock Style="{StaticResource MetricLabelStyle}" Text="Resolution" />
                <TextBlock x:Name="ResolutionValueTextBlock"
                           Style="{StaticResource MetricValueStyle}"
                           Text="---" />
            </StackPanel>

            <Border Grid.Column="1" Style="{StaticResource MetricSeparatorStyle}" />

            <StackPanel Grid.Column="2" MinWidth="160">
                <TextBlock Style="{StaticResource MetricLabelStyle}" Text="Frame Rate" />
                <TextBlock x:Name="FrameRateValueTextBlock"
                           Style="{StaticResource MetricValueStyle}"
                           Text="---" />
            </StackPanel>

            <Border Grid.Column="3" Style="{StaticResource MetricSeparatorStyle}" />

            <StackPanel Grid.Column="4" MinWidth="220">
                <TextBlock Style="{StaticResource MetricLabelStyle}" Text="Sender" />
                <TextBlock x:Name="SenderValueTextBlock"
                           Style="{StaticResource MetricValueStyle}"
                           Text="---" />
            </StackPanel>
        </Grid>

        <Grid x:Name="StateMetricsPanel"
              Margin="92,42,92,0"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="34" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel MinWidth="190">
                <TextBlock Style="{StaticResource MetricLabelStyle}" Text="Status" />
                <TextBlock x:Name="StateValueTextBlock"
                           Style="{StaticResource MetricValueStyle}"
                           Text="---" />
            </StackPanel>

            <Border Grid.Column="1" Style="{StaticResource MetricSeparatorStyle}" />

            <StackPanel Grid.Column="2" MinWidth="230">
                <TextBlock x:Name="SecondaryLabelTextBlock"
                           Style="{StaticResource MetricLabelStyle}"
                           Text="Duration" />
                <TextBlock x:Name="SecondaryValueTextBlock"
                           Style="{StaticResource MetricValueStyle}"
                           Text="00:00:00" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1"
              Margin="128,18,128,16"
              VerticalAlignment="Top">
            <Border Background="#252525"
                    CornerRadius="34"
                    Padding="12"
                    Height="430">
                <Border x:Name="PreviewViewportBorder"
                        Background="#666666"
                        CornerRadius="24"
                        ClipToBounds="True"
                        SizeChanged="PreviewViewportBorder_OnSizeChanged">
                    <Grid>
                        <Image x:Name="LivePreviewImage"
                               Stretch="Uniform"
                               Visibility="Collapsed"
                               SnapsToDevicePixels="True" />

                        <Image x:Name="PlaybackImage"
                               Visibility="Collapsed"
                               Stretch="Uniform"
                               IsHitTestVisible="False"
                               SnapsToDevicePixels="True"
                               RenderOptions.BitmapScalingMode="HighQuality" />

                        <Grid x:Name="OverlayHost"
                              IsHitTestVisible="False"
                              Panel.ZIndex="5">
                            <TextBlock x:Name="NoSignalOverlayTextBlock"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="58"
                                       FontWeight="Bold"
                                       Foreground="#F4F4F4"
                                       Text="NO SIGNAL"
                                       TextOptions.TextFormattingMode="Display" />

                            <StackPanel x:Name="RecordingOverlayPanel"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <TextBlock x:Name="RecordingOverlayTitleTextBlock"
                                           HorizontalAlignment="Center"
                                           FontSize="42"
                                           FontWeight="SemiBold"
                                           Foreground="#F4F4F4"
                                           Text="Recording in progress"
                                           TextOptions.TextFormattingMode="Display" />
                                <TextBlock x:Name="RecordingOverlayBodyTextBlock"
                                           Margin="0,12,0,0"
                                           HorizontalAlignment="Center"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="#E2E2E2"
                                           Text="Live preview is stopped while recording."
                                           TextOptions.TextFormattingMode="Display" />
                            </StackPanel>

                            <StackPanel x:Name="EncodingOverlayPanel"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <TextBlock Text="Encoding..."
                                           HorizontalAlignment="Center"
                                           FontSize="52"
                                           FontWeight="SemiBold"
                                           Foreground="#F4F4F4"
                                           TextOptions.TextFormattingMode="Display" />
                                <Grid Width="360"
                                      Height="8"
                                      Margin="0,18,0,0">
                                    <Border Background="#949494"
                                            CornerRadius="4" />
                                    <Border x:Name="EncodingProgressFill"
                                            HorizontalAlignment="Left"
                                            Width="0"
                                            Background="#F4F4F4"
                                            CornerRadius="4" />
                                </Grid>
                            </StackPanel>

                            <TextBlock x:Name="DoneOverlayTextBlock"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="54"
                                       FontWeight="SemiBold"
                                       Foreground="#F4F4F4"
                                       Text="Done!"
                                       Visibility="Collapsed"
                                       TextOptions.TextFormattingMode="Display" />
                        </Grid>
                    </Grid>
                </Border>
            </Border>
        </Grid>

        <Grid Grid.Row="2"
              Margin="92,18,92,36">
            <StackPanel x:Name="InitialActionsPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left">
                <Button x:Name="RecordButton"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#A73438"
                        BorderBrush="#C05055"
                        Click="RecordButton_OnClick" />
                <Button x:Name="SettingsButton"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#113D39"
                        BorderBrush="#2E5D57"
                        Click="SettingsButton_OnClick" />
            </StackPanel>

            <StackPanel x:Name="RecordingActionsPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        Visibility="Collapsed">
                <Button x:Name="DoneButton"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#7AA300"
                        BorderBrush="#96BD1A"
                        Click="DoneButton_OnClick" />
                <Button x:Name="PauseResumeButton"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#113D39"
                        BorderBrush="#2E5D57"
                        Click="PauseResumeButton_OnClick" />
            </StackPanel>

            <Grid x:Name="PlaybackActionsPanel"
                  Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Button x:Name="RemoveButton"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#A73438"
                            BorderBrush="#C05055"
                            Click="RemoveButton_OnClick" />
                    <Button x:Name="BackwardButton"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#113D39"
                            BorderBrush="#2E5D57"
                            Click="BackwardButton_OnClick" />
                    <Button x:Name="PlayPauseButton"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#113D39"
                            BorderBrush="#2E5D57"
                            Click="PlayPauseButton_OnClick" />
                    <Button x:Name="ForwardButton"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#113D39"
                            BorderBrush="#2E5D57"
                            Click="ForwardButton_OnClick" />
                </StackPanel>

                <Button x:Name="EncodeButton"
                        Grid.Column="1"
                        Style="{StaticResource ActionButtonStyle}"
                        Margin="0"
                        HorizontalAlignment="Right"
                        Background="#7AA300"
                        BorderBrush="#96BD1A"
                        Click="EncodeButton_OnClick" />
            </Grid>

            <Grid x:Name="EncodingActionsPanel"
                  Visibility="Collapsed">
                <Button x:Name="CancelButton"
                        Style="{StaticResource ActionButtonStyle}"
                        Margin="0"
                        HorizontalAlignment="Right"
                        Background="#113D39"
                        BorderBrush="#2E5D57"
                        Click="CancelButton_OnClick" />
            </Grid>

            <Grid x:Name="EncodedActionsPanel"
                  Visibility="Collapsed">
                <Button x:Name="ContinueButton"
                        Style="{StaticResource ActionButtonStyle}"
                        Margin="0"
                        HorizontalAlignment="Right"
                        Background="#113D39"
                        BorderBrush="#2E5D57"
                        Click="ContinueButton_OnClick" />
            </Grid>
        </Grid>
    </Grid>
</Window>
