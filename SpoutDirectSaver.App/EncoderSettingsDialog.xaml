<Window x:Class="SpoutDirectSaver.App.EncoderSettingsDialog"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings"
        Width="900"
        Height="760"
        MinWidth="840"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#303030"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E9F0F7" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#EEF6FF" />
            <Setter Property="Background" Value="#0F1821" />
            <Setter Property="BorderBrush" Value="#355165" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="CaretBrush" Value="#EEF6FF" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#15212C" />
            <Setter Property="Background" Value="#F1F4F7" />
            <Setter Property="BorderBrush" Value="#355165" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="ItemTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Foreground="#15212C"
                                   Text="{Binding}" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#15212C" />
            <Setter Property="Background" Value="#F1F4F7" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#CDE9FF" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#9ED3FF" />
                    <Setter Property="Foreground" Value="#102234" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EAF2FB" />
            <Setter Property="Margin" Value="0,0,16,0" />
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#96AABD" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="EncoderCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#101820" />
            <Setter Property="BorderBrush" Value="#294051" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14" />
        </Style>
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#F4F4F4" />
            <Setter Property="Background" Value="#113D39" />
            <Setter Property="BorderBrush" Value="#2E5D57" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Padding" Value="14,8" />
        </Style>
    </Window.Resources>

    <Border Background="#343434"
            BorderBrush="#1F1F1F"
            BorderThickness="1"
            CornerRadius="18"
            Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="28"
                               FontWeight="SemiBold"
                               Text="Settings" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#96AABD"
                               Text="Current encoder settings" />
                </StackPanel>
                <Button x:Name="ResetButton"
                        DockPanel.Dock="Right"
                        Style="{StaticResource DialogButtonStyle}"
                        Margin="12,0,0,0"
                        Background="#30414D"
                        BorderBrush="#4E6678"
                        Click="ResetButton_OnClick"
                        Content="Reset" />
            </DockPanel>

            <StackPanel Grid.Row="1" Margin="0,16,0,0">
                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Format" />
                <ComboBox x:Name="FormatComboBox"
                          Height="34"
                          VerticalContentAlignment="Center"
                          SelectionChanged="FormatComboBox_OnSelectionChanged" />
                <TextBlock x:Name="FormatDescriptionTextBlock"
                           Margin="0,10,0,0"
                           Foreground="#96AABD"
                           TextWrapping="Wrap"
                           Text="Choose the encoder format used when you record." />
            </StackPanel>

            <ScrollViewer Grid.Row="2"
                          Margin="0,16,0,0"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border x:Name="PngMovNoteBorder"
                            Style="{StaticResource EncoderCardStyle}"
                            Visibility="Collapsed"
                            Margin="0,0,0,14"
                            Background="#143038"
                            BorderBrush="#2C666C">
                        <TextBlock Foreground="#C4E1E5"
                                   TextWrapping="Wrap"
                                   Text="PNG / MOV has no additional tuning beyond the format choice." />
                    </Border>

                    <Border x:Name="EncoderSettingsSectionBorder"
                            BorderBrush="#365163"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="14">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#152330" Offset="0" />
                                <GradientStop Color="#0E171F" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel x:Name="EncoderSettingsRootPanel" Orientation="Vertical">
                            <Button x:Name="ResetEncoderSettingsButton"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,0,14"
                                    Padding="12,8"
                                    Background="#30414D"
                                    BorderBrush="#4E6678"
                                    Click="ResetEncoderSettingsButton_OnClick"
                                    Content="Reset settings" />

                            <Border Style="{StaticResource EncoderCardStyle}"
                                    Margin="0,0,0,14"
                                    Background="#143038"
                                    BorderBrush="#2C666C">
                                <TextBlock Foreground="#C4E1E5"
                                           TextWrapping="Wrap"
                                           Text="RGB uses the raw quality / speed slider, plus low latency and advanced rate-control options." />
                            </Border>

                            <Border Style="{StaticResource EncoderCardStyle}">
                                <StackPanel>
                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               Text="RGB (Media Foundation)" />

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Quality vs speed (raw)" />
                                            <Slider x:Name="RgbQualityVsSpeedSlider"
                                                    Minimum="0"
                                                    Maximum="100"
                                                    SmallChange="1"
                                                    LargeChange="10"
                                                    TickFrequency="10"
                                                    AutoToolTipPlacement="BottomRight"
                                                    ValueChanged="EncoderSettingsSlider_OnChanged" />
                                            <TextBlock x:Name="RgbQualityVsSpeedValueTextBlock"
                                                       Margin="0,6,0,0"
                                                       Foreground="#D8E7F2"
                                                       Text="16" />
                                        </StackPanel>
                                        <StackPanel x:Name="RgbQualityPanel" Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Target quality" />
                                            <Slider x:Name="RgbQualitySlider"
                                                    Minimum="1"
                                                    Maximum="100"
                                                    SmallChange="1"
                                                    LargeChange="5"
                                                    TickFrequency="5"
                                                    AutoToolTipPlacement="BottomRight"
                                                    ValueChanged="EncoderSettingsSlider_OnChanged" />
                                            <TextBlock x:Name="RgbQualityValueTextBlock"
                                                       Margin="0,6,0,0"
                                                       Foreground="#D8E7F2"
                                                       Text="70" />
                                        </StackPanel>
                                    </Grid>

                                    <WrapPanel Margin="0,14,0,0">
                                        <CheckBox x:Name="RgbLowLatencyCheckBox"
                                                  Content="Low latency" />
                                    </WrapPanel>

                                    <WrapPanel Margin="0,14,0,0">
                                        <CheckBox x:Name="RgbUseConstantQpCheckBox"
                                                  Content="Use constant QP"
                                                  Checked="EncoderSettingsToggle_OnChanged"
                                                  Unchecked="EncoderSettingsToggle_OnChanged" />
                                    </WrapPanel>

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Rate control" />
                                            <ComboBox x:Name="RgbRateControlComboBox"
                                                      Height="32"
                                                      VerticalContentAlignment="Center"
                                                      SelectionChanged="EncoderSettingsSelection_OnChanged" />
                                        </StackPanel>
                                        <StackPanel x:Name="RgbTargetBitratePanel" Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Target bitrate (Mbps)" />
                                            <TextBox x:Name="RgbTargetBitrateTextBox"
                                                     Height="32"
                                                     VerticalContentAlignment="Center" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Buffer size (MB)" />
                                            <TextBox x:Name="RgbBufferSizeTextBox"
                                                     Height="32"
                                                     VerticalContentAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel x:Name="RgbConstantQpPanel" Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Constant QP" />
                                            <TextBox x:Name="RgbConstantQpTextBox"
                                                     Height="32"
                                                     VerticalContentAlignment="Center" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Min QP" />
                                            <TextBox x:Name="RgbMinQpTextBox"
                                                     Height="32"
                                                     VerticalContentAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Max QP" />
                                            <TextBox x:Name="RgbMaxQpTextBox"
                                                     Height="32"
                                                     VerticalContentAlignment="Center" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="GOP size" />
                                            <TextBox x:Name="RgbGopSizeTextBox"
                                                     Height="32"
                                                     VerticalContentAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Content type" />
                                            <ComboBox x:Name="RgbContentTypeComboBox"
                                                      Height="32"
                                                      VerticalContentAlignment="Center" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Margin="0,14,0,0">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Worker threads" />
                                        <TextBox x:Name="RgbWorkerThreadsTextBox"
                                                 Height="32"
                                                 VerticalContentAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource EncoderCardStyle}"
                                    Margin="0,14,0,0">
                                <StackPanel>
                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               Text="Alpha (ffmpeg / NVENC)" />

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Preset" />
                                            <Slider x:Name="AlphaPresetSlider"
                                                    Minimum="1"
                                                    Maximum="7"
                                                    SmallChange="1"
                                                    LargeChange="1"
                                                    TickFrequency="1"
                                                    IsSnapToTickEnabled="True"
                                                    AutoToolTipPlacement="BottomRight"
                                                    ValueChanged="EncoderSettingsSlider_OnChanged" />
                                            <TextBlock x:Name="AlphaPresetValueTextBlock"
                                                       Margin="0,6,0,0"
                                                       Foreground="#D8E7F2"
                                                       Text="P3 / Fast" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Tune" />
                                            <ComboBox x:Name="AlphaTuneComboBox"
                                                      Height="32"
                                                      VerticalContentAlignment="Center" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel x:Name="AlphaConstantQualityPanel" Grid.Column="0">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Constant quality (CQ)" />
                                            <Slider x:Name="AlphaConstantQualitySlider"
                                                    Minimum="0"
                                                    Maximum="51"
                                                    SmallChange="1"
                                                    LargeChange="2"
                                                    TickFrequency="2"
                                                    AutoToolTipPlacement="BottomRight"
                                                    ValueChanged="EncoderSettingsSlider_OnChanged" />
                                            <TextBlock x:Name="AlphaConstantQualityValueTextBlock"
                                                       Margin="0,6,0,0"
                                                       Foreground="#D8E7F2"
                                                       Text="19" />
                                        </StackPanel>
                                        <StackPanel x:Name="AlphaConstantQpPanel" Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Constant QP" />
                                            <Slider x:Name="AlphaConstantQpSlider"
                                                    Minimum="0"
                                                    Maximum="51"
                                                    SmallChange="1"
                                                    LargeChange="2"
                                                    TickFrequency="2"
                                                    AutoToolTipPlacement="BottomRight"
                                                    ValueChanged="EncoderSettingsSlider_OnChanged" />
                                            <TextBlock x:Name="AlphaConstantQpValueTextBlock"
                                                       Margin="0,6,0,0"
                                                       Foreground="#D8E7F2"
                                                       Text="23" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Rate control" />
                                            <ComboBox x:Name="AlphaRateControlComboBox"
                                                      Height="32"
                                                      VerticalContentAlignment="Center"
                                                      SelectionChanged="EncoderSettingsSelection_OnChanged" />
                                        </StackPanel>
                                        <StackPanel x:Name="AlphaTargetBitratePanel" Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Target bitrate (Mbps)" />
                                            <TextBox x:Name="AlphaTargetBitrateTextBox"
                                                     Height="32"
                                                     VerticalContentAlignment="Center" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Lookahead" />
                                            <TextBox x:Name="AlphaLookaheadTextBox"
                                                     Height="32"
                                                     VerticalContentAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Min QP" />
                                            <TextBox x:Name="AlphaMinQpTextBox"
                                                     Height="32"
                                                     VerticalContentAlignment="Center" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Max QP" />
                                            <TextBox x:Name="AlphaMaxQpTextBox"
                                                     Height="32"
                                                     VerticalContentAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel x:Name="AlphaAqStrengthPanel" Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="AQ strength" />
                                            <TextBox x:Name="AlphaAqStrengthTextBox"
                                                     Height="32"
                                                     VerticalContentAlignment="Center" />
                                        </StackPanel>
                                    </Grid>

                                    <WrapPanel Margin="0,14,0,0">
                                        <CheckBox x:Name="AlphaSpatialAqCheckBox"
                                                  Content="Spatial AQ"
                                                  Checked="EncoderSettingsToggle_OnChanged"
                                                  Unchecked="EncoderSettingsToggle_OnChanged" />
                                        <CheckBox x:Name="AlphaTemporalAqCheckBox"
                                                  Content="Temporal AQ"
                                                  Checked="EncoderSettingsToggle_OnChanged"
                                                  Unchecked="EncoderSettingsToggle_OnChanged" />
                                        <CheckBox x:Name="AlphaZeroLatencyCheckBox"
                                                  Content="Zero latency" />
                                    </WrapPanel>

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="B-frames" />
                                            <TextBox x:Name="AlphaBFramesTextBox"
                                                     Height="32"
                                                     VerticalContentAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="GOP size" />
                                            <TextBox x:Name="AlphaGopSizeTextBox"
                                                     Height="32"
                                                     VerticalContentAlignment="Center" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Profile" />
                                            <ComboBox x:Name="AlphaProfileComboBox"
                                                      Height="32"
                                                      VerticalContentAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Level" />
                                            <ComboBox x:Name="AlphaLevelComboBox"
                                                      Height="32"
                                                      VerticalContentAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="3"
                        Margin="0,16,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="CancelButton"
                        Style="{StaticResource DialogButtonStyle}"
                        Margin="0,0,12,0"
                        Background="#30414D"
                        BorderBrush="#4E6678"
                        Click="CancelButton_OnClick"
                        Content="Cancel" />
                <Button x:Name="ApplyButton"
                        Style="{StaticResource DialogButtonStyle}"
                        Background="#7AA300"
                        BorderBrush="#96BD1A"
                        Click="ApplyButton_OnClick"
                        Content="Apply" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
