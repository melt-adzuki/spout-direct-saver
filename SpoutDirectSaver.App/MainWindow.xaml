<Window x:Class="SpoutDirectSaver.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        mc:Ignorable="d"
        Title="Spout Direct Saver"
        Width="1360"
        Height="900"
        MinWidth="1120"
        MinHeight="760"
        Background="#10151C">
    <Window.Resources>
        <DrawingBrush x:Key="CheckerBrush"
                      TileMode="Tile"
                      Stretch="None"
                      Viewport="0,0,24,24"
                      ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#1B2530" Geometry="M0,0 H24 V24 H0 Z" />
                    <GeometryDrawing Brush="#243140" Geometry="M0,0 H12 V12 H0 Z" />
                    <GeometryDrawing Brush="#243140" Geometry="M12,12 H24 V24 H12 Z" />
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F2F6FB" />
            <Setter Property="Background" Value="#1D5C58" />
            <Setter Property="BorderBrush" Value="#2C7B76" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E9F0F7" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#EEF6FF" />
            <Setter Property="Background" Value="#0F1821" />
            <Setter Property="BorderBrush" Value="#355165" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="CaretBrush" Value="#EEF6FF" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#EEF6FF" />
            <Setter Property="Background" Value="#0F1821" />
            <Setter Property="BorderBrush" Value="#355165" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EAF2FB" />
            <Setter Property="Margin" Value="0,0,16,0" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#96AABD" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="EncoderCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#101820" />
            <Setter Property="BorderBrush" Value="#294051" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1.05*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.1*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="#18212B"
                BorderBrush="#263445"
                BorderThickness="1"
                CornerRadius="14"
                Padding="18"
                Margin="0,0,0,16">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Vertical" DockPanel.Dock="Left">
                    <TextBlock FontSize="26" FontWeight="SemiBold" Text="Spout Direct Saver" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#9DB1C6"
                               Text="Spout2 のフレームを受信し、変化フレームのみを可変fpsで動画化します。" />
                </StackPanel>
                <Border DockPanel.Dock="Right"
                        Background="#121820"
                        BorderBrush="#324558"
                        BorderThickness="1"
                        CornerRadius="999"
                        Padding="14,8">
                    <TextBlock x:Name="HeaderStatusTextBlock"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Text="初期化中..." />
                </Border>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="0"
                Background="#18212B"
                BorderBrush="#263445"
                BorderThickness="1"
                CornerRadius="18"
                Padding="16"
                Margin="0,0,16,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,12">
                    <StackPanel Orientation="Vertical" DockPanel.Dock="Left">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="ライブ入力" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="#8FA4B9"
                                   Text="RGBA 8bit で受信し、ここではチェック柄の上にプレビュー表示します。" />
                    </StackPanel>
                    <Border DockPanel.Dock="Right"
                            Background="#121820"
                            BorderBrush="#324558"
                            BorderThickness="1"
                            CornerRadius="999"
                            Padding="12,6">
                        <TextBlock x:Name="LivePreviewBadgeTextBlock"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Text="入力待ち" />
                    </Border>
                </DockPanel>

                <Border Grid.Row="1"
                        Background="{StaticResource CheckerBrush}"
                        BorderBrush="#33475C"
                        BorderThickness="1"
                        CornerRadius="14"
                        ClipToBounds="True">
                    <Grid>
                        <Image x:Name="LivePreviewImage" Stretch="Uniform" />
                        <Border x:Name="LivePreviewPlaceholderBorder"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Background="#A010151C"
                                CornerRadius="12"
                                Padding="18,14">
                            <TextBlock x:Name="LivePreviewPlaceholderTextBlock"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="Spout sender を待っています" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="1"
                Background="#18212B"
                BorderBrush="#263445"
                BorderThickness="1"
                CornerRadius="18"
                Padding="16"
                Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="18" FontWeight="SemiBold" Text="受信状況" />

                <TextBlock Grid.Row="1" Margin="0,18,0,4" Foreground="#8FA4B9" Text="Sender" />
                <TextBlock Grid.Row="2" x:Name="SenderNameTextBlock" FontSize="16" FontWeight="SemiBold" Text="-" />

                <TextBlock Grid.Row="3" Margin="0,16,0,4" Foreground="#8FA4B9" Text="解像度 / sender fps" />
                <TextBlock Grid.Row="4" x:Name="SenderMetricsTextBlock" FontSize="16" FontWeight="SemiBold" Text="- / -" />

                <TextBlock Grid.Row="5" Margin="0,16,0,4" Foreground="#8FA4B9" Text="録画経過" />
                <TextBlock Grid.Row="6" x:Name="RecordingElapsedTextBlock" FontSize="16" FontWeight="SemiBold" Text="00:00:00.000" />

                <TextBlock Grid.Row="7" Margin="0,16,0,4" Foreground="#8FA4B9" Text="状態" />
                <Border Grid.Row="8"
                        Background="#121820"
                        BorderBrush="#324558"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="12">
                    <TextBlock x:Name="RecorderStatusTextBlock"
                               TextWrapping="Wrap"
                               Foreground="#DCE8F5"
                               Text="録画前です。" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Grid.ColumnSpan="2"
                Background="#18212B"
                BorderBrush="#263445"
                BorderThickness="1"
                CornerRadius="18"
                Padding="16"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.02*" />
                    <ColumnDefinition Width="0.98*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Vertical">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="保存形式" />
                        <ComboBox Grid.Row="0"
                                  x:Name="FormatComboBox"
                                  Margin="0,10,0,0"
                                  Height="34"
                                  VerticalContentAlignment="Center"
                                  SelectionChanged="FormatComboBox_OnSelectionChanged" />
                        <TextBlock Grid.Row="0"
                                   x:Name="FormatDescriptionTextBlock"
                                   Margin="0,10,0,0"
                                   Foreground="#96AABD"
                                   TextWrapping="Wrap"
                                   Text="RGBA をそのまま保存できる形式を選びます。" />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   FontWeight="SemiBold"
                                   Text="保存先" />
                        <TextBox Grid.Column="1"
                                 x:Name="OutputPathTextBox"
                                 Height="34"
                                 IsReadOnly="True"
                                 VerticalContentAlignment="Center" />
                        <Button Grid.Column="2"
                                x:Name="BrowseOutputButton"
                                Margin="10,0,0,0"
                                Click="BrowseOutputButton_OnClick"
                                Content="保存先を選択" />
                    </Grid>
                </Grid>

                <Border x:Name="EncoderSettingsSectionBorder"
                        Grid.Column="1"
                        BorderBrush="#365163"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#152330" Offset="0" />
                            <GradientStop Color="#0E171F" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  MaxHeight="390">
                        <StackPanel x:Name="EncoderSettingsRootPanel" Orientation="Vertical">
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="Encoder Tuning" />
                            <TextBlock Margin="0,4,0,14"
                                       Foreground="#96AABD"
                                       TextWrapping="Wrap"
                                       Text="普段は preset / tune / rate control あたりだけで十分です。細かい調整は必要なときだけ開けるようにしてあります。" />

                            <Border Style="{StaticResource EncoderCardStyle}"
                                    Margin="0,0,0,14"
                                    Background="#143038"
                                    BorderBrush="#2C666C">
                                <StackPanel>
                                    <TextBlock FontSize="13"
                                               FontWeight="SemiBold"
                                               Text="Quick Guide" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#C4E1E5"
                                               TextWrapping="Wrap"
                                               Text="RGB は bitrate と low latency、alpha は preset / tune / CQ を主に触れば十分です。" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource EncoderCardStyle}">
                                <StackPanel>
                                    <DockPanel LastChildFill="False">
                                        <StackPanel DockPanel.Dock="Left">
                                            <TextBlock FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Text="RGB (Media Foundation)" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="#8FA4B9"
                                                       Text="本体の RGB 動画。通常は bitrate と low latency だけ調整すれば十分です。" />
                                        </StackPanel>
                                        <Border DockPanel.Dock="Right"
                                                Background="#16303D"
                                                BorderBrush="#325468"
                                                BorderThickness="1"
                                                CornerRadius="999"
                                                Padding="10,5">
                                            <TextBlock FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Text="Main Video" />
                                        </Border>
                                    </DockPanel>

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Rate control" />
                                            <ComboBox x:Name="RgbRateControlComboBox"
                                                      Height="32"
                                                      VerticalContentAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Target bitrate (Mbps)" />
                                            <TextBox x:Name="RgbTargetBitrateTextBox"
                                                     Height="32"
                                                     VerticalContentAlignment="Center" />
                                        </StackPanel>
                                    </Grid>

                                    <WrapPanel Margin="0,14,0,0">
                                        <CheckBox x:Name="RgbLowLatencyCheckBox"
                                                  Content="Low latency" />
                                    </WrapPanel>

                                    <Expander Header="RGB advanced"
                                              Margin="0,16,0,0"
                                              Foreground="#E9F0F7"
                                              IsExpanded="False">
                                        <StackPanel Margin="0,12,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="16" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Buffer size (MB)" />
                                                    <TextBox x:Name="RgbBufferSizeTextBox"
                                                             Height="32"
                                                             VerticalContentAlignment="Center" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Quality vs speed" />
                                                    <TextBox x:Name="RgbQualityVsSpeedTextBox"
                                                             Height="32"
                                                             VerticalContentAlignment="Center" />
                                                </StackPanel>
                                            </Grid>

                                            <WrapPanel Margin="0,14,0,0">
                                                <CheckBox x:Name="RgbUseConstantQpCheckBox"
                                                          Content="Use constant QP"
                                                          Checked="EncoderSettingsToggle_OnChanged"
                                                          Unchecked="EncoderSettingsToggle_OnChanged" />
                                            </WrapPanel>

                                            <StackPanel x:Name="RgbConstantQpPanel"
                                                        Margin="0,14,0,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="16" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Constant QP" />
                                                        <TextBox x:Name="RgbConstantQpTextBox"
                                                                 Height="32"
                                                                 VerticalContentAlignment="Center" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Min / Max QP" />
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="22" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBox x:Name="RgbMinQpTextBox"
                                                                     Grid.Column="0"
                                                                     Height="32"
                                                                     VerticalContentAlignment="Center" />
                                                            <TextBlock Grid.Column="1"
                                                                       VerticalAlignment="Center"
                                                                       HorizontalAlignment="Center"
                                                                       Text="/" />
                                                            <TextBox x:Name="RgbMaxQpTextBox"
                                                                     Grid.Column="2"
                                                                     Height="32"
                                                                     VerticalContentAlignment="Center" />
                                                        </Grid>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>

                                            <Grid Margin="0,14,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="16" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="GOP size" />
                                                    <TextBox x:Name="RgbGopSizeTextBox"
                                                             Height="32"
                                                             VerticalContentAlignment="Center" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Content type" />
                                                    <ComboBox x:Name="RgbContentTypeComboBox"
                                                              Height="32"
                                                              VerticalContentAlignment="Center" />
                                                </StackPanel>
                                            </Grid>

                                            <StackPanel Margin="0,14,0,0">
                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Worker threads" />
                                                <TextBox x:Name="RgbWorkerThreadsTextBox"
                                                         Height="32"
                                                         VerticalContentAlignment="Center" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource EncoderCardStyle}"
                                    Margin="0,14,0,0">
                                <StackPanel>
                                    <DockPanel LastChildFill="False">
                                        <StackPanel DockPanel.Dock="Left">
                                            <TextBlock FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Text="Alpha (ffmpeg / NVENC)" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="#8FA4B9"
                                                       Text="sidecar alpha 動画。通常は preset / tune / rate control と CQ だけで十分です。" />
                                        </StackPanel>
                                        <Border DockPanel.Dock="Right"
                                                Background="#2A2038"
                                                BorderBrush="#56406F"
                                                BorderThickness="1"
                                                CornerRadius="999"
                                                Padding="10,5">
                                            <TextBlock FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Text="Alpha Sidecar" />
                                        </Border>
                                    </DockPanel>

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Preset" />
                                            <ComboBox x:Name="AlphaPresetComboBox"
                                                      Height="32"
                                                      VerticalContentAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Tune" />
                                            <ComboBox x:Name="AlphaTuneComboBox"
                                                      Height="32"
                                                      VerticalContentAlignment="Center" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Rate control" />
                                            <ComboBox x:Name="AlphaRateControlComboBox"
                                                      Height="32"
                                                      VerticalContentAlignment="Center"
                                                      SelectionChanged="EncoderSettingsSelection_OnChanged" />
                                        </StackPanel>
                                        <StackPanel x:Name="AlphaTargetBitratePanel"
                                                    Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Target bitrate (Mbps)" />
                                            <TextBox x:Name="AlphaTargetBitrateTextBox"
                                                     Height="32"
                                                     VerticalContentAlignment="Center" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel x:Name="AlphaConstantQualityPanel"
                                                Margin="0,14,0,0">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Constant quality (CQ)" />
                                        <TextBox x:Name="AlphaConstantQualityTextBox"
                                                 Height="32"
                                                 VerticalContentAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel x:Name="AlphaConstantQpPanel"
                                                Margin="0,14,0,0">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Constant QP" />
                                        <TextBox x:Name="AlphaConstantQpTextBox"
                                                 Height="32"
                                                 VerticalContentAlignment="Center" />
                                    </StackPanel>

                                    <Expander Header="Alpha advanced"
                                              Margin="0,16,0,0"
                                              Foreground="#E9F0F7"
                                              IsExpanded="False">
                                        <StackPanel Margin="0,12,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="16" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Lookahead" />
                                                    <TextBox x:Name="AlphaLookaheadTextBox"
                                                             Height="32"
                                                             VerticalContentAlignment="Center" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Min / Max QP" />
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="22" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox x:Name="AlphaMinQpTextBox"
                                                                 Grid.Column="0"
                                                                 Height="32"
                                                                 VerticalContentAlignment="Center" />
                                                        <TextBlock Grid.Column="1"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center"
                                                                   Text="/" />
                                                        <TextBox x:Name="AlphaMaxQpTextBox"
                                                                 Grid.Column="2"
                                                                 Height="32"
                                                                 VerticalContentAlignment="Center" />
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>

                                            <WrapPanel Margin="0,14,0,0">
                                                <CheckBox x:Name="AlphaSpatialAqCheckBox"
                                                          Content="Spatial AQ"
                                                          Checked="EncoderSettingsToggle_OnChanged"
                                                          Unchecked="EncoderSettingsToggle_OnChanged" />
                                                <CheckBox x:Name="AlphaTemporalAqCheckBox"
                                                          Content="Temporal AQ"
                                                          Checked="EncoderSettingsToggle_OnChanged"
                                                          Unchecked="EncoderSettingsToggle_OnChanged" />
                                                <CheckBox x:Name="AlphaZeroLatencyCheckBox"
                                                          Content="Zero latency" />
                                            </WrapPanel>

                                            <StackPanel x:Name="AlphaAqStrengthPanel"
                                                        Margin="0,14,0,0">
                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="AQ strength" />
                                                <TextBox x:Name="AlphaAqStrengthTextBox"
                                                         Height="32"
                                                         VerticalContentAlignment="Center" />
                                            </StackPanel>

                                            <Grid Margin="0,14,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="16" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="B-frames" />
                                                    <TextBox x:Name="AlphaBFramesTextBox"
                                                             Height="32"
                                                             VerticalContentAlignment="Center" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="GOP size" />
                                                    <TextBox x:Name="AlphaGopSizeTextBox"
                                                             Height="32"
                                                             VerticalContentAlignment="Center" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid Margin="0,14,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="16" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Profile" />
                                                    <ComboBox x:Name="AlphaProfileComboBox"
                                                              Height="32"
                                                              VerticalContentAlignment="Center" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Level" />
                                                    <ComboBox x:Name="AlphaLevelComboBox"
                                                              Height="32"
                                                              VerticalContentAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Grid.ColumnSpan="2"
                Background="#18212B"
                BorderBrush="#263445"
                BorderThickness="1"
                CornerRadius="18"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,12">
                    <StackPanel Orientation="Vertical" DockPanel.Dock="Left">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="録画プレビュー" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="#8FA4B9"
                                   Text="停止後に保存した動画をそのまま再生します。" />
                    </StackPanel>
                    <TextBlock x:Name="PreviewFileTextBlock"
                               DockPanel.Dock="Right"
                               VerticalAlignment="Center"
                               Foreground="#96AABD"
                               Text="まだ録画されていません" />
                </DockPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <Button x:Name="StartRecordingButton" Click="StartRecordingButton_OnClick" Content="録画開始" />
                    <Button x:Name="StopRecordingButton"
                            Background="#7A2F36"
                            BorderBrush="#A84A53"
                            Click="StopRecordingButton_OnClick"
                            Content="録画停止" />
                    <Button x:Name="RerecordButton"
                            Background="#344756"
                            BorderBrush="#476175"
                            Click="RerecordButton_OnClick"
                            Content="再録画" />
                    <Button x:Name="PlayPreviewButton"
                            Background="#395C41"
                            BorderBrush="#4B7C56"
                            Click="PlayPreviewButton_OnClick"
                            Content="再生" />
                    <Button x:Name="PausePreviewButton"
                            Background="#344756"
                            BorderBrush="#476175"
                            Click="PausePreviewButton_OnClick"
                            Content="一時停止" />
                </StackPanel>

                <Border Grid.Row="2"
                        Margin="0,14,0,0"
                        Background="#121820"
                        BorderBrush="#33475C"
                        BorderThickness="1"
                        CornerRadius="14"
                        ClipToBounds="True">
                    <Grid>
                        <vlc:VideoView x:Name="PreviewVideoView" />
                        <Border x:Name="PreviewPlaceholderBorder"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Background="#A010151C"
                                CornerRadius="12"
                                Padding="18,14">
                            <TextBlock x:Name="PreviewPlaceholderTextBlock"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="録画停止後にここでプレビュー再生できます" />
                        </Border>
                    </Grid>
                </Border>

                <Slider Grid.Row="3"
                        x:Name="SeekSlider"
                        Margin="0,14,0,0"
                        Height="28"
                        Minimum="0"
                        Maximum="1"
                        IsSnapToTickEnabled="False"
                        PreviewMouseLeftButtonDown="SeekSlider_OnPreviewMouseLeftButtonDown"
                        PreviewMouseLeftButtonUp="SeekSlider_OnPreviewMouseLeftButtonUp" />

                <DockPanel Grid.Row="4" Margin="0,10,0,0">
                    <TextBlock x:Name="PreviewStatusTextBlock"
                               DockPanel.Dock="Left"
                               Foreground="#DCE8F5"
                               Text="プレビュー待機中です。" />
                    <TextBlock x:Name="PreviewTimeTextBlock"
                               DockPanel.Dock="Right"
                               Foreground="#9DB1C6"
                               Text="00:00:00.000 / 00:00:00.000" />
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
